AGENT_RUNNER_PROVIDER=openai-tools
AGENT_RUNNER_APP_NAME=TradeSkills Agent Runner
AGENT_RUNNER_TOOL_GATEWAY_TIMEOUT_SECONDS=20
AGENT_RUNNER_OPENAI_MODEL=gpt-5.1-codex-mini
AGENT_RUNNER_OPENAI_TIMEOUT_SECONDS=60
AGENT_RUNNER_OPENAI_TEMPERATURE=0.1
AGENT_RUNNER_OPENAI_MAX_TOOL_ROUNDS=8
AGENT_RUNNER_OPENAI_MAX_RETRIES=4
AGENT_RUNNER_OPENAI_RETRY_BASE_DELAY_SECONDS=2
AGENT_RUNNER_OPENAI_RETRY_MAX_DELAY_SECONDS=30

# You can also set OPENAI_API_KEY / OPENAI_BASE_URL directly in your shell.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
