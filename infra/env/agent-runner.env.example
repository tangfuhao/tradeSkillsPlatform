# ==============================
# 服务基础信息与跨域
# ==============================
# Runner 提供方标识：当前项目只实现 openai-tools 路由。
AGENT_RUNNER_PROVIDER=openai-tools
# Runner 服务名称：显示在健康检查和日志里。
AGENT_RUNNER_APP_NAME=TradeSkills Agent Runner
# 允许访问 Runner 的前端来源列表：不在这里的 Web Origin 会被 CORS 拦住。
AGENT_RUNNER_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# 调用 API Tool Gateway 的超时时间（秒）：工具执行太慢会在这里超时。
AGENT_RUNNER_TOOL_GATEWAY_TIMEOUT_SECONDS=20

# ==============================
# OpenAI / Azure / Novita 凭证与路由
# ==============================
# OpenAI API Key：当模型路由到官方 OpenAI 时使用。
AGENT_RUNNER_OPENAI_API_KEY=
# OpenAI Base URL：默认是官方接口，也可以切到兼容网关。
AGENT_RUNNER_OPENAI_BASE_URL=https://api.openai.com/v1
# Azure OpenAI API Key：当模型路由到 Azure 时使用。
AGENT_RUNNER_AZURE_OPENAI_API_KEY=
# Azure OpenAI Base URL：通常形如 https://<resource>.openai.azure.com/openai 。
AGENT_RUNNER_AZURE_OPENAI_BASE_URL=
# Azure OpenAI API 版本：需与目标 Azure 部署支持的版本匹配。
AGENT_RUNNER_AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Novita API Key：当模型路由到 Novita 时使用。
AGENT_RUNNER_NOVITA_API_KEY=
# Novita Base URL：默认是官方 Novita OpenAI 兼容入口。
AGENT_RUNNER_NOVITA_BASE_URL=https://api.novita.ai/openai/v1
# 是否允许把 pa/*、az/* 之类前缀模型路由到非官方兼容网关：打开前要明确知道自己在做什么。
AGENT_RUNNER_ALLOW_COMPAT_MODEL_PREFIX_ROUTING=false

# ==============================
# 模型选择与推理策略
# ==============================
# 默认模型名：决定 Runner 实际调用哪个模型/路由。
AGENT_RUNNER_OPENAI_MODEL=pa/gpt-5.4
# OpenAI 接线协议：当前项目只支持 responses。
AGENT_RUNNER_OPENAI_WIRE_API=responses
# 全局推理强度：影响模型思考深度和耗时。
AGENT_RUNNER_OPENAI_REASONING_EFFORT=medium
# 执行阶段专用推理强度：留空时回退到全局推理强度。
AGENT_RUNNER_EXECUTE_REASONING_EFFORT=
# 单次模型请求超时（秒）：推理等级高时过小会导致工具轮次超时。
AGENT_RUNNER_OPENAI_TIMEOUT_SECONDS=120
# 采样温度：越低越稳定，越高越发散。
AGENT_RUNNER_OPENAI_TEMPERATURE=0.1

# ==============================
# 工具轮次与失败重试
# ==============================
# 单次执行允许的最大工具轮数：超过后会停止继续调用工具。
AGENT_RUNNER_OPENAI_MAX_TOOL_ROUNDS=8
# SDK 请求最大重试次数：用于暂时性网络/服务错误。
AGENT_RUNNER_OPENAI_MAX_RETRIES=4
# 重试基础退避秒数：第一次重试等待的起始值。
AGENT_RUNNER_OPENAI_RETRY_BASE_DELAY_SECONDS=2
# 重试最大退避秒数：指数退避不会超过这个上限。
AGENT_RUNNER_OPENAI_RETRY_MAX_DELAY_SECONDS=30
