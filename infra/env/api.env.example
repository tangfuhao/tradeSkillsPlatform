TRADE_SKILLS_DATA_DIR=/app/data/runtime
TRADE_SKILLS_DATABASE_URL=sqlite:////app/data/runtime/trade_skills.db
TRADE_SKILLS_AGENT_RUNNER_BASE_URL=http://agent-runner:8100
TRADE_SKILLS_TOOL_GATEWAY_BASE_URL=http://api:8000
TRADE_SKILLS_TOOL_GATEWAY_SHARED_SECRET=change-me-demo-secret
TRADE_SKILLS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
TRADE_SKILLS_PREVIEW_WINDOW_DAYS=90
TRADE_SKILLS_DEFAULT_BENCHMARK=market_passive_reference

# Historical market data
TRADE_SKILLS_HISTORICAL_DATA_DIR=/app/data
TRADE_SKILLS_HISTORICAL_CSV_GLOB=allswap-candlesticks-*.csv
TRADE_SKILLS_HISTORICAL_BASE_TIMEFRAME=1m
TRADE_SKILLS_STARTUP_SYNC_BLOCKING=true
TRADE_SKILLS_STARTUP_SYNC_REQUIRE_SUCCESS=true
TRADE_SKILLS_STARTUP_SYNC_TARGET_OFFSET_DAYS=1

# OKX incremental catch-up
TRADE_SKILLS_OKX_API_BASE_URL=https://www.okx.com
TRADE_SKILLS_OKX_INCREMENTAL_SYNC_ENABLED=true
TRADE_SKILLS_OKX_REQUEST_PAUSE_SECONDS=0.15
TRADE_SKILLS_OKX_HISTORY_LIMIT=100
TRADE_SKILLS_OKX_INCREMENTAL_MAX_GAP_DAYS=7
TRADE_SKILLS_MARKET_UNIVERSE_REFRESH_INTERVAL_SECONDS=300
TRADE_SKILLS_MARKET_SYNC_CYCLE_SYMBOL_LIMIT=40
TRADE_SKILLS_MARKET_SYNC_TIER1_TARGET_SECONDS=60
TRADE_SKILLS_MARKET_SYNC_TIER2_TARGET_SECONDS=180
TRADE_SKILLS_MARKET_SYNC_TIER3_TARGET_SECONDS=900
TRADE_SKILLS_MARKET_SYNC_SYMBOL_MAX_PAGES_PER_RUN=20
TRADE_SKILLS_MARKET_SYNC_RETRY_LIMIT=3
TRADE_SKILLS_MARKET_SYNC_NON_RETRYABLE_DELAY_SECONDS=900
TRADE_SKILLS_MARKET_SYNC_LEASE_TTL_SECONDS=600
TRADE_SKILLS_MARKET_SYNC_BOOTSTRAP_WINDOW_HOURS=72
TRADE_SKILLS_MARKET_SYNC_TIER1_SYMBOL_COUNT=50
TRADE_SKILLS_MARKET_SYNC_REQUIRED_COVERAGE_RATIO=0.95
TRADE_SKILLS_MARKET_SYNC_QUEUE_ENABLED=true
TRADE_SKILLS_MARKET_SYNC_REDIS_URL=redis://redis:6379/0
TRADE_SKILLS_MARKET_SYNC_WORKER_POLL_SECONDS=1
TRADE_SKILLS_MARKET_SYNC_WORKER_HEARTBEAT_TTL_SECONDS=30
