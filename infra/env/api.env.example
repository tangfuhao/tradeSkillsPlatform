# ==============================
# 基础服务与对外接口
# ==============================
# API 服务名称：显示在健康检查和日志里。
TRADE_SKILLS_APP_NAME=TradeSkills API
# API 路由前缀：前端和其他服务访问 API 时的统一前缀。
TRADE_SKILLS_API_PREFIX=/api/v1
# Agent Runner 服务地址：API 会把策略执行请求发到这里。
TRADE_SKILLS_AGENT_RUNNER_BASE_URL=http://agent-runner:8100
# API 调 Runner 的超时时间（秒）：过小会让长推理/多工具执行提前失败。
TRADE_SKILLS_AGENT_RUNNER_TIMEOUT_SECONDS=180
# Tool Gateway 对外基址：Runner 回调 API 内部工具时使用。
TRADE_SKILLS_TOOL_GATEWAY_BASE_URL=http://api:8000
# Tool Gateway 共享密钥：保护内部工具网关接口，需与 Runner 侧一致。
TRADE_SKILLS_TOOL_GATEWAY_SHARED_SECRET=change-me-demo-secret
# 允许访问 API 的前端来源列表：不在这里的 Web Origin 会被 CORS 拦住。
TRADE_SKILLS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ==============================
# 本地存储与控制台默认表现
# ==============================
# API 运行数据目录：SQLite 数据库、运行时产物等都写到这里。
TRADE_SKILLS_DATA_DIR=/app/data/runtime
# 数据库连接串：API 读写的主数据库位置。
TRADE_SKILLS_DATABASE_URL=sqlite:////app/data/runtime/trade_skills.db
# 控制台默认预览时间窗（天）：影响前端默认展示的近端数据窗口。
TRADE_SKILLS_PREVIEW_WINDOW_DAYS=90
# 默认基准名称：回测汇总里展示的基准标签。
TRADE_SKILLS_DEFAULT_BENCHMARK=market_passive_reference
# 市场扫描默认返回数量：scan_market 等能力默认给多少候选。
TRADE_SKILLS_MARKET_SCAN_LIMIT_DEFAULT=50

# ==============================
# 本地历史数据与启动同步
# ==============================
# 本地历史 CSV 目录：启动导入和回测基础数据都从这里读。
TRADE_SKILLS_HISTORICAL_DATA_DIR=/app/data
# 历史 CSV 匹配模式：只有文件名命中这个 glob 的文件会被导入。
TRADE_SKILLS_HISTORICAL_CSV_GLOB=allswap-candlesticks-*.csv
# 历史基础周期：当前系统假设原始落库周期为 1m，并据此向上聚合。
TRADE_SKILLS_HISTORICAL_BASE_TIMEFRAME=1m
# 启动时是否阻塞等待首轮市场数据同步：true 时 API 会等同步流程跑完再 ready。
TRADE_SKILLS_STARTUP_SYNC_BLOCKING=true
# 启动同步失败时是否直接阻止 API 启动：false 时即使失败或关闭增量同步也能起服务。
TRADE_SKILLS_STARTUP_SYNC_REQUIRE_SUCCESS=true
# 启动追数目标偏移天数：1 表示尽量追到“接近昨天结束 / 当前最近已闭合 bar”。
TRADE_SKILLS_STARTUP_SYNC_TARGET_OFFSET_DAYS=1

# ==============================
# OKX 数据源与增量追数
# ==============================
# OKX API 基址：增量同步和交易所元数据刷新都访问这个地址。
TRADE_SKILLS_OKX_API_BASE_URL=https://www.okx.com
# 是否开启 OKX 增量同步：false 表示只使用本地已存在数据，不继续从交易所补最新数据。
TRADE_SKILLS_OKX_INCREMENTAL_SYNC_ENABLED=true
# OKX 请求间隔秒数：越小追数越快，但越容易触发限流。
TRADE_SKILLS_OKX_REQUEST_PAUSE_SECONDS=0.15
# 每次 OKX 历史 K 线请求的分页大小：越大请求次数越少，但单次响应可能更慢。
TRADE_SKILLS_OKX_HISTORY_LIMIT=100
# 允许的“增量补齐”最大断档天数：超过这个阈值会改走 recent bootstrap，而不是简单续接。
TRADE_SKILLS_OKX_INCREMENTAL_MAX_GAP_DAYS=7

# ==============================
# 市场同步调度与覆盖门槛
# ==============================
# 市场合约列表刷新间隔（秒）：决定多久重新拉一次交易所活跃合约宇宙。
TRADE_SKILLS_MARKET_UNIVERSE_REFRESH_INTERVAL_SECONDS=300
# 进程内同步循环间隔（秒）：未启用队列模式时，后台线程每隔多久跑一轮同步。
TRADE_SKILLS_MARKET_SYNC_LOOP_INTERVAL_SECONDS=60
# 实时数据新鲜度阈值（秒）：超过这个年龄可视为“实时覆盖偏旧”。
TRADE_SKILLS_LIVE_DATA_FRESHNESS_SECONDS=180
# 市场同步调度心跳间隔（秒）：用于驱动计划/调度层刷新。
TRADE_SKILLS_MARKET_SYNC_SCHEDULE_INTERVAL_SECONDS=15
# 每轮最多处理多少个 symbol：越大追数越快，但单轮更重。
TRADE_SKILLS_MARKET_SYNC_CYCLE_SYMBOL_LIMIT=40
# Tier1 高优先级标的目标新鲜度（秒）。
TRADE_SKILLS_MARKET_SYNC_TIER1_TARGET_SECONDS=60
# Tier2 普通活跃标的目标新鲜度（秒）。
TRADE_SKILLS_MARKET_SYNC_TIER2_TARGET_SECONDS=180
# Tier3 低优先级 / 回补标的目标新鲜度（秒）。
TRADE_SKILLS_MARKET_SYNC_TIER3_TARGET_SECONDS=900
# Tier1 标的数量：交易量最重要的一批合约会被优先追新。
TRADE_SKILLS_MARKET_SYNC_TIER1_SYMBOL_COUNT=50
# 可派发覆盖所需的最低新鲜覆盖率：低于阈值时会阻塞或降级。
TRADE_SKILLS_MARKET_SYNC_REQUIRED_COVERAGE_RATIO=0.95
# 多少次未刷新后把合约视为 delisted：用于清理过期标的。
TRADE_SKILLS_MARKET_SYNC_DELIST_AFTER_MISSED_REFRESHES=3

# ==============================
# 单标的同步预算与失败恢复
# ==============================
# 单个 symbol 每轮最多拉多少页 OKX 历史数据：避免一个落后标的独占整轮预算。
TRADE_SKILLS_MARKET_SYNC_SYMBOL_MAX_PAGES_PER_RUN=20
# 单个 symbol 每轮最多占用多少秒：进一步限制单标的同步成本。
TRADE_SKILLS_MARKET_SYNC_SYMBOL_TIME_BUDGET_SECONDS=20
# 同步失败后的最大重试次数：用于暂时性错误。
TRADE_SKILLS_MARKET_SYNC_RETRY_LIMIT=3
# 非可重试错误的冷却时间（秒）：避免错误配置导致高频重复打接口。
TRADE_SKILLS_MARKET_SYNC_NON_RETRYABLE_DELAY_SECONDS=900
# 同步租约 TTL（秒）：防止多个 worker/线程同时处理同一个 symbol。
TRADE_SKILLS_MARKET_SYNC_LEASE_TTL_SECONDS=600
# 新标的或严重落后标的的 recent bootstrap 时间窗（小时）。
TRADE_SKILLS_MARKET_SYNC_BOOTSTRAP_WINDOW_HOURS=72

# ==============================
# 队列模式与外部 Worker
# ==============================
# 是否启用队列模式：true 时把同步任务推到 Redis/worker，而不是 API 进程内线程。
TRADE_SKILLS_MARKET_SYNC_QUEUE_ENABLED=true
# Redis 地址：队列模式下市场同步任务的传输层。
TRADE_SKILLS_MARKET_SYNC_REDIS_URL=redis://redis:6379/0
# Worker 轮询 Redis 的间隔（秒）。
TRADE_SKILLS_MARKET_SYNC_WORKER_POLL_SECONDS=1
# Worker 心跳 TTL（秒）：控制台和 health 接口据此判断外部 worker 是否仍存活。
TRADE_SKILLS_MARKET_SYNC_WORKER_HEARTBEAT_TTL_SECONDS=30
